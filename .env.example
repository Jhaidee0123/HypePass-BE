NODE_ENV=development
PORT=3000

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=admin
DB_NAME=HypePassDB

# Better Auth (server)
BETTER_AUTH_SECRET=replace-with-32-byte-base64
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:8090
CORS_ORIGIN=http://localhost:8090,http://lvh.me:8090

# Wompi (Colombia)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
WOMPI_API_URL=

# Wompi Payouts (Pagos a Terceros / SPT) — separate product from gateway.
# Activate at https://wompi.com/es/co/soluciones/payouts.html (2-5 business
# days). Until WOMPI_PAYOUTS_ENABLED=true the dispersion sweeper is no-op.
WOMPI_PAYOUTS_API_URL=https://api.wompi.co/v1
WOMPI_PAYOUTS_PRIVATE_KEY=
WOMPI_PAYOUTS_ORIGIN_ACCOUNT_ID=
WOMPI_PAYOUTS_ENABLED=false
PAYOUT_DISPERSION_BATCH_SIZE=50

# MercadoPago Marketplace (Split Payments). Each organizer connects
# their own MP account via OAuth; HypePass charges a marketplace_fee.
# See: https://www.mercadopago.com.co/developers/en/docs/split-payments
MERCADOPAGO_API_URL=https://api.mercadopago.com
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_REDIRECT_URI=https://api.hypepass.co/api/payments/mp/callback
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_STATE_SECRET=
MERCADOPAGO_ENABLED=false

# AES-256-GCM key used to encrypt at-rest 3rd-party credentials
# (MP access_token, etc). Generate with: openssl rand -base64 32
PAYMENT_CRED_ENCRYPTION_KEY=

# Resend (transactional email)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=HypePass <no-reply@yourdomain.com>

# Admin notifications (comma-separated)
ADMIN_NOTIFICATION_EMAILS=admin@hypepass.com

# Cloudinary (event media storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=

# Platform configuration
PLATFORM_FEE_PERCENTAGE_PRIMARY=10
PLATFORM_FEE_PERCENTAGE_RESALE=10
INVENTORY_HOLD_MINUTES=10
DEFAULT_QR_VISIBLE_HOURS_BEFORE=24

# QR tokens
QR_HMAC_SECRET=replace-with-32-byte-base64
QR_TOKEN_TTL_SECONDS=60
CHECKIN_GRACE_MINUTES=120

# Resale / marketplace
RESALE_PRICE_CAP_MULTIPLIER=1.2
RESALE_RESERVATION_MINUTES=10
RESALE_MAX_DAYS=30
PAYOUT_ESCROW_HOURS_AFTER_EVENT=48

# Rate limiting (defaults + tighter windows on /auth and /checkout)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
THROTTLE_AUTH_LIMIT=20
THROTTLE_CHECKOUT_LIMIT=10

# Background sweepers (holds, listings, reservations)
SWEEPER_ENABLED=true
